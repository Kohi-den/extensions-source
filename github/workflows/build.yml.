name: Build Extension
on: [push, pull_request, workflow_dispatch]

jobs:
  build:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout
        uses: actions/checkout@v4 # تم التحديث للإصدار 4 المضمون

      - name: Set up JDK 11
        uses: actions/setup-java@v4 # تم التحديث للإصدار 4
        with:
          java-version: '11'
          distribution: 'temurin'
          cache: gradle

      - name: Grant execute permission for gradlew
        run: chmod +x gradlew

      - name: Build with Gradle
        run: ./gradlew assembleRelease --stacktrace

      - name: Upload APK
        uses: actions/upload-artifact@v4 # تم التحديث للإصدار 4
        with:
          name: anime3rb-extension-apk
          path: app/build/outputs/apk/release/*.apk
